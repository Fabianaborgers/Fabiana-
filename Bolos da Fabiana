  <style>
    body {
      font-family: 'Montserrat', sans-serif;
      background: #fff8f5;
      color: #3b1f2b;
      margin: 0;
      padding: 0;
    }

    header {
      background: #701f3c;
      color: #fff;
      text-align: center;
      padding: 40px 20px 20px;
    }

    h1 {
      font-size: 2.8em;
