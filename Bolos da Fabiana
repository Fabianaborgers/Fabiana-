      padding-left: 0;
      margin: 10px 0 20px;
    }

    li {
      margin: 8px 0;
      padding-left: 20px;
      position: relative;
    }

    li::before {
      content: "🍰";
      position: absolute;
      left: 0;
    }

    .btn {
      display: block;
      width: fit-content;
      margin: 30px auto 0;
      background: #701f3c;
      color: #fff;
      text-decoration: none;
      padding: 15px 25px;
      border-radius: 8px;
      font-weight: bold;
      transition: background 0.3s ease;
    }

    .btn:hover {
      background: #4e142a;
    }

    footer {
      text-align: center;
      background: #f0e0da;
      padding: 20px;
      font-size: 0.95em;
    }

    footer a {
      color: #701f3c;
      font-weight: bold;
      text-decoration: none;
    }

    footer a:hover {
      text-decoration: underline;
    }
